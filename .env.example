# 이어서 client 빌드타임 설정 템플릿
# Flutter 는 .env 를 자동 로드하지 않는다. 아래 값은 빌드/실행 시 주입한다:
#   flutter run --dart-define=API_BASE_URL=... --dart-define=GOOGLE_SERVER_CLIENT_ID=...
# 또는: flutter run --dart-define-from-file=client/.env.json (KEY:VALUE JSON)
# 소셜/리버스 클라이언트 ID 는 네이티브 설정(Info.plist/AndroidManifest)에도 함께 넣어야 한다.
# 실제 키는 커밋하지 말 것 — 플레이스홀더만.

# ── API ───────────────────────────────────────────────────
API_BASE_URL=http://localhost:8080/api/v1

# ── 소셜 로그인 (네이티브 설정의 TODO_* 와 함께 채울 것) ──
# Google Cloud Console → Credentials
GOOGLE_IOS_CLIENT_ID=
GOOGLE_REVERSED_CLIENT_ID=
GOOGLE_SERVER_CLIENT_ID=
# Kakao Developers → 네이티브 앱 키
KAKAO_NATIVE_APP_KEY=
# Apple Developer → Service ID (Sign in with Apple)
APPLE_SERVICE_ID=

# ── 관측성 (Sentry) ───────────────────────────────────────
# SENTRY_DSN 미설정(빈 값)이면 Sentry 비활성 — 외부 전송 0. 키 넣으면 즉시 활성.
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
# 성능 트레이스 샘플링 0.0~1.0 (0.0=에러만).
SENTRY_TRACES_SAMPLE_RATE=0.0
